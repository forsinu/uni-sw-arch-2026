# ===== JWT / ASYMMETRIC KEYS =====
JWT_ALGORITHM=RS256
JWT_KEY_SIZE=4096
JWT_KEY_ID="auth-key-v1"
JWT_KEYS_DIR=./Secrets
JWT_PRIVATE_KEY_HOST_PATH=./Secrets/jwtPrivate.pem
JWT_PUBLIC_KEY_HOST_PATH=./Secrets/jwtPublic.pem
JWT_PRIVATE_KEY_CONTAINER_PATH=/run/secrets/jwtPrivate.pem
JWT_PUBLIC_KEY_CONTAINER_PATH=/run/secrets/jwtPublic.pem
JWT_PUBLIC_KEY_SERVICE_PATH="/.well-known/jwks.json"

HOST_SERVICE_TOKEN_PATH=./Secrets/serviceToken.txt
CONTAINER_SERVICE_TOKEN_PATH=/run/secrets/serviceToken.txt

# ===== RABBITMQ CONFIG =====
RABBITMQ_SERVICE_PORT=5672
RABBITMQ_SERVICE_USER=service
RABBITMQ_SERVICE_PASSWORD=service
RABBITMQ_SERVICE_VHOST=/
RABBITMQ_SERVICE_HOST=rabbitmq
