APP_DOMAIN=app.docker.localhost

# ===== AUTH DATABASE =====
DB_AUTH_USER=authUser
DB_AUTH_PASSWD=auth_password
DB_AUTH_NAME=auth_db

# ===== AUTH SERVICE =====
AUTH_SERVICE_DIR=./Services/AuthService
AUTH_SERVICE_PORT=8000
AUTH_API_PREFIX=/auth

# ===== FEDERATION DATABASE =====
DB_FEDERATION_USER=federationUser
DB_FEDERATION_PASSWD=federation_password
DB_FEDERATION_NAME=federation_db

# ===== FEDERATION SERVICE =====
FEDERATION_SERVICE_DIR=./Services/FedService
FEDERATION_SERVICE_PORT=8001
FEDERATION_API_PREFIX=/federation

# ===== COMPETITION DATABASE =====
DB_COMPETITION_USER=competition_user
DB_COMPETITION_PASSWD=competition_password
DB_COMPETITION_NAME=competition_db

# ===== COMPETITION SERVICE =====
COMPETITION_SERVICE_DIR=./Services/CompetitionService
COMPETITION_SERVICE_PORT=8002
COMPETITION_API_PREFIX=/competition

# ===== JWT / ASYMMETRIC KEYS =====
JWT_ALGORITHM=RS256
JWT_KEY_SIZE=4096
JWT_KEYS_DIR=./Secrets
JWT_PRIVATE_KEY_HOST_PATH=./Secrets/jwtPrivate.pem
JWT_PUBLIC_KEY_HOST_PATH=./Secrets/jwtPublic.pem
JWT_PRIVATE_KEY_CONTAINER_PATH=/run/secrets/jwtPrivate.pem
JWT_PUBLIC_KEY_CONTAINER_PATH=/run/secrets/jwtPublic.pem
