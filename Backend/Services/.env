APP_DOMAIN=app.docker.localhost

# ===== AUTH DATABASE =====
DB_AUTH_USER=authUser
DB_AUTH_PASSWD=auth_password
DB_AUTH_NAME=auth_db
DB_AUTH_ECHO=false

# ===== AUTH SERVICE =====
AUTH_SERVICE_HOSTNAME=auth-service
AUTH_SERVICE_DIR=./Services/AuthService
AUTH_SERVICE_PORT=8000
AUTH_API_PREFIX=/auth
AUTH_API_VERSION=1

# ===== AUTH CONFIG =====
AUTH_LOG_LEVEL=INFO
AUTH_APP_LOGGER_NAME=auth-service
AUTH_LOGGER_HANDLER_NAME=auth-service.logger
AUTH_DB_LOGGER_NAME=auth-service.database
AUTH_ROUTING_LOGGER_NAME=auth-service.routing

AUTH_ROUTING_LOG_REQUESTS=true
AUTH_ROUTING_LOG_RESPONSES=false


# ===== FEDERATION DATABASE =====
DB_FEDERATION_USER=federationUser
DB_FEDERATION_PASSWD=federation_password
DB_FEDERATION_NAME=federation_db

# ===== FEDERATION SERVICE =====
FEDERATION_SERVICE_DIR=./Services/FederationService
FEDERATION_SERVICE_HOSTNAME=federation-service
FEDERATION_SERVICE_PORT=8001
FEDERATION_API_PREFIX=/fed
FEDERATION_API_VERSION=1

# ===== FEDERATION CONFIG =====
FEDERATION_LOG_LEVEL=INFO
FEDERATION_APP_LOGGER_NAME=federation-service
FEDERATION_LOGGER_HANDLER_NAME=federation-service.logger
FEDERATION_DB_LOGGER_NAME=federation-service.database
FEDERATION_ROUTING_LOGGER_NAME=federation-service.routing

FEDERATION_ROUTING_LOG_REQUESTS=true
FEDERATION_ROUTING_LOG_RESPONSES=false

# ===== COMPETITION DATABASE =====
DB_COMPETITION_USER=competition_user
DB_COMPETITION_PASSWD=competition_password
DB_COMPETITION_NAME=competition_db


# ===== COMPETITION CONFIG =====
COMPETITION_LOG_LEVEL=INFO
COMPETITION_APP_LOGGER_NAME=competition-service
COMPETITION_LOGGER_HANDLER_NAME=competition-service.logger
COMPETITION_DB_LOGGER_NAME=competition-service.database
COMPETITION_ROUTING_LOGGER_NAME=competition-service.routing

COMPETITION_ROUTING_LOG_REQUESTS=true
COMPETITION_ROUTING_LOG_RESPONSES=false

# ===== COMPETITION SERVICE =====
COMPETITION_SERVICE_DIR=./Services/CompetitionService
COMPETITION_SERVICE_HOSTNAME=competition-service
COMPETITION_SERVICE_PORT=8002
COMPETITION_API_PREFIX=/comp
COMPETITION_API_VERSION=1


