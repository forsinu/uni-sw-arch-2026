# ==== Database Settings ====
DB_USER=postgres
DB_PASSWD=mysecurepassword
DB_NAME=auth_db
# DB_PORT_DEBUG=6666

RATE_LIMIT_STORAGE_URI="memory://"

# ==== Security Settings ====
AT_EXP_MIN=15
RT_EXP_MIN=5040
JWT_ALGORITHM=RS256
PASSWD_LENGTH=12
MAX_SESSIONS=3

PRIVATE_KEY_PATH = "keys/private_key.pem"
PUBLIC_KEY_PATH = "keys/public_key.pem"

MAX_ATTEMPTS=5
WINDOW_ATTEMPTS_MIN=15

# ==== Service Settings ====
SERVICE_PORT=8000
